# Supabase Postgres connection string.
# Get this from: Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@db.your-project-ref.supabase.co:5432/postgres"

# Long random secret used to sign login sessions (JWT). Generate your own,
# e.g. by running: openssl rand -base64 48
AUTH_SECRET="CHANGE-ME-TO-A-LONG-RANDOM-STRING"

# TOTP secret for admin sign-up. Add this exact key to Google Authenticator /
# Authy as a manual "setup key" (Time-based, 6 digits, SHA1). Whoever enters
# the current 6-digit code from that app while registering becomes an admin.
# Generate your own secret (32 base32 characters) — do not reuse this example.
ADMIN_TOTP_SECRET="CHANGE-ME-SEE-SETUP-INSTRUCTIONS-IN-README"

# 32-byte key (base64) used to encrypt AiProvider.apiKey at rest
# (AES-256-GCM). Generate your own with: openssl rand -base64 32
# If this is missing or not exactly 32 bytes after decoding, the app will
# refuse to start encrypting/decrypting provider keys.
API_KEY_ENCRYPTION_SECRET="CHANGE-ME-RUN-openssl-rand--base64-32"

# Supabase Storage — used by the image upload feature.
# Project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase Dashboard -> Project Settings -> API -> service_role key.
# This is a SECRET — never expose it to the frontend or commit it.
SUPABASE_SERVICE_ROLE_KEY="CHANGE-ME-YOUR-SERVICE-ROLE-KEY"
